<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Eval Compare: {{ run_a.run_id }} vs {{ run_b.run_id }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
         max-width: 1200px; margin: 2em auto; padding: 0 1em; color: #222; }
  h1 { border-bottom: 2px solid #ccc; padding-bottom: .3em; }
  h2 { color: #444; margin-top: 2em; }
  table { border-collapse: collapse; width: 100%; margin: 1em 0; font-size: .92em; }
  th, td { border: 1px solid #ddd; padding: .4em .6em; text-align: left; }
  th { background: #f5f5f5; }
  .num { text-align: right; font-variant-numeric: tabular-nums; }
  .pos { color: #1a7f1a; }
  .neg { color: #b22222; }
  .sig { font-weight: 700; }
  .star { color: #d4a200; }
</style>
</head>
<body>
<h1>Eval Comparison</h1>
<p><strong>A:</strong> <code>{{ run_a.run_id }}</code> ({{ run_a.config_name }}) &nbsp;
   <strong>B:</strong> <code>{{ run_b.run_id }}</code> ({{ run_b.config_name }})</p>

<h2>Metric Deltas</h2>
<table>
  <thead><tr>
    <th>Metric</th><th>Dataset</th>
    <th class="num">A mean</th><th class="num">B mean</th>
    <th class="num">Δ (B − A)</th><th class="num">p</th><th></th>
  </tr></thead>
  <tbody>
    {% for d in deltas %}
    <tr>
      <td><code>{{ d.metric_name }}</code></td>
      <td>{{ d.dataset or "<all>" }}</td>
      <td class="num">{{ "%.4f"|format(d.a_mean) }}</td>
      <td class="num">{{ "%.4f"|format(d.b_mean) }}</td>
      <td class="num {% if d.delta > 0 %}pos{% elif d.delta < 0 %}neg{% endif %} {% if d.significant %}sig{% endif %}">
        {{ "%+.4f"|format(d.delta) }}
      </td>
      <td class="num">{{ "%.4f"|format(d.p_value) }}</td>
      <td>{% if d.significant %}<span class="star">★</span>{% endif %}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
<p><em>★ = p &lt; 0.05 (paired permutation test, n=10000)</em></p>

<h2>Top Per-Question Differences</h2>
<table>
  <thead><tr>
    <th>Question ID</th><th>Dataset</th>
    <th class="num">A score</th><th class="num">B score</th><th class="num">Δ</th>
  </tr></thead>
  <tbody>
    {% for d in per_question_diff %}
    <tr>
      <td><code>{{ d.question_id }}</code></td>
      <td>{{ d.dataset }}</td>
      <td class="num">{{ "%.4f"|format(d.a_score) }}</td>
      <td class="num">{{ "%.4f"|format(d.b_score) }}</td>
      <td class="num {% if d.delta > 0 %}pos{% elif d.delta < 0 %}neg{% endif %}">
        {{ "%+.4f"|format(d.delta) }}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>

</body>
</html>
