# Dev backend image — hot-reload via uvicorn --reload
#
# Source code is bind-mounted in, so changes reflect instantly.
# Only requirements are baked into the image for fast rebuilds.

FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Source code comes from volume mount — not COPY
# Tests and src/ are mounted at runtime via docker-compose volumes

EXPOSE 8001

CMD ["uvicorn", "src.api.main:app", "--host", "0.0.0.0", "--port", "8001", "--reload"]
