# Dev frontend image — Vite dev server with HMR
#
# Source code is bind-mounted for instant hot module replacement.
# node_modules live inside the container (not mounted from host).

FROM node:22-alpine

WORKDIR /app

# Install deps first (cached layer)
COPY package.json package-lock.json ./
RUN npm ci

# Source comes from volume mount at runtime
# Only node_modules/ stays in the image

EXPOSE 3000

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
